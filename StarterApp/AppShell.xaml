<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RentalApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:RentalApp.Views"
    Shell.FlyoutBehavior="Flyout"
    Shell.TabBarIsVisible="True">

    <!-- Login/Register Pages (outside of main navigation) -->
    <ShellContent
        Route="LoginPage"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Shell.FlyoutItemIsVisible="False"
        Shell.TabBarIsVisible="False" />

    <!-- Main App with Bottom TabBar Navigation -->
    <TabBar Route="MainTabs">
        <ShellContent
            Title="Browse"
            Route="ItemsListPage"
            ContentTemplate="{DataTemplate views:ItemsListPage}"
            Icon="list.png" />

        <ShellContent
            Title="My Items"
            Route="MyItemsPage"
            ContentTemplate="{DataTemplate views:MyItemsPage}"
            Icon="box.png" />

        <ShellContent
            Title="Rentals"
            Route="RentalsPage"
            ContentTemplate="{DataTemplate views:RentalsPage}"
            Icon="calendar.png" />
    </TabBar>

    <!-- Flyout Menu Items (for logout, etc.) -->
    <MenuItem
        Text="Logout"
        Command="{Binding LogoutCommand}"
        IconImageSource="logout.png" />

</Shell>
