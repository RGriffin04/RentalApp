<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:RentalApp.Converters"
             xmlns:local="clr-namespace:RentalApp"
             x:Class="RentalApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Existing Converters -->
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:StringToBoolConverter x:Key="StringToBoolConverter" />
            <converters:StringIsNotNullOrEmptyConverter x:Key="StringIsNotNullOrEmptyConverter" />
            <converters:BoolToYesNoConverter x:Key="BoolToYesNoConverter" />
            <converters:BoolToTextConverter x:Key="BoolToTextConverter" />
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:AvailabilityConverter x:Key="AvailabilityConverter" />
            <converters:IntToBoolConverter x:Key="IntToBoolConverter" />
            <converters:StringEqualityConverter x:Key="StringEqualityConverter" />

            <!-- UK Formatting Converters -->
            <converters:DateToUkStringConverter x:Key="DateToUkString" />
            <converters:ShortDateToUkStringConverter x:Key="ShortDateToUkString" />
            <converters:CurrencyToUkStringConverter x:Key="CurrencyToUkString" />
            <converters:DistanceToStringConverter x:Key="DistanceToString" />

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
