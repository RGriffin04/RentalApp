<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="RentalApp.Views.MyItemsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RentalApp.ViewModels"
             xmlns:converters="clr-namespace:RentalApp.Converters"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*">

        <!-- Error Message -->
        <Border Grid.Row="0"
                BackgroundColor="#FFEBEE"
                Stroke="#F44336"
                StrokeThickness="1"
                Padding="15"
                Margin="15,15,15,0"
                IsVisible="{Binding HasError}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{Binding ErrorMessage}"
                       TextColor="#D32F2F"
                       FontSize="14"
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="✕"
                        Command="{Binding ClearErrorCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#D32F2F"
                        FontSize="18"
                        Padding="10,0"
                        WidthRequest="40" />
            </Grid>
        </Border>

        <!-- Main Content -->
        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Items}"
                            SelectionMode="None"
                            Margin="15">
                <CollectionView.EmptyView>
                    <StackLayout Padding="50" VerticalOptions="Center">
                        <Label Text="You haven't added any items yet"
                               FontSize="18"
                               HorizontalOptions="Center"
                               TextColor="Gray" />
                        <Button Text="Create Your First Item"
                                Command="{Binding CreateItemCommand}"
                                BackgroundColor="#2196F3"
                                TextColor="White"
                                Margin="0,20,0,0"
                                HorizontalOptions="Center"
                                WidthRequest="250" />
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="15"
                               Margin="0,5"
                               CornerRadius="10"
                               BorderColor="LightGray"
                               HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MyItemsViewModel}}, Path=ViewItemCommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
                                <!-- Title -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Title}"
                                       FontSize="18"
                                       FontAttributes="Bold" />

                                <!-- Price -->
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding DailyPrice, Converter={StaticResource CurrencyToUkString}}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="Green"
                                       HorizontalOptions="End" />

                                <!-- Category -->
                                <Label Grid.Row="1" Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding Category.Name}"
                                       FontSize="14"
                                       TextColor="Gray"
                                       Margin="0,5,0,0" />

                                <!-- Description -->
                                <Label Grid.Row="2" Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding Description}"
                                       FontSize="14"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2"
                                       Margin="0,5,0,0" />

                                <!-- Availability Status -->
                                <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                                      ColumnDefinitions="Auto,*" Margin="0,10,0,0">
                                    <BoxView Grid.Column="0"
                                             WidthRequest="12"
                                             HeightRequest="12"
                                             CornerRadius="6"
                                             VerticalOptions="Center"
                                             Color="{Binding IsAvailable, Converter={StaticResource BoolToColorConverter}}" />
                                    <Label Grid.Column="1"
                                           Text="{Binding IsAvailable, Converter={StaticResource AvailabilityConverter}}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"
                                           Margin="8,0,0,0"
                                           TextColor="{Binding IsAvailable, Converter={StaticResource BoolToColorConverter}}" />
                                </Grid>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Floating Action Button for Create Item -->
        <Button Grid.Row="1"
                Text="+"
                FontSize="32"
                Command="{Binding CreateItemCommand}"
                BackgroundColor="#2196F3"
                TextColor="White"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="30"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="20" />
    </Grid>
</ContentPage>
