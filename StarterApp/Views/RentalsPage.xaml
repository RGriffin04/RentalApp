<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="RentalApp.Views.RentalsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RentalApp.ViewModels"
             xmlns:models="clr-namespace:RentalApp.Database.Models;assembly=RentalApp.Database"
             x:Name="RentalsPageRoot"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Error Message -->
        <Border Grid.Row="0"
                BackgroundColor="#FFEBEE"
                Stroke="#F44336"
                StrokeThickness="1"
                Padding="15"
                Margin="10"
                IsVisible="{Binding HasError}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="{Binding ErrorMessage}"
                       TextColor="#D32F2F"
                       FontSize="14"
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="✕"
                        Command="{Binding ClearErrorCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#D32F2F"
                        FontSize="18"
                        Padding="10,0"
                        WidthRequest="40" />
            </Grid>
        </Border>

        <!-- Tabs -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="10,0">
            <Button Grid.Column="0"
                    Text="My Rentals"
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="0" />
            <Button Grid.Column="1"
                    Text="My Listings"
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="1" />
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="2" Margin="10">

            <!-- My Rentals Tab -->
            <RefreshView IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}"
                         IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}">
                <CollectionView ItemsSource="{Binding MyRentals}"
                                SelectionMode="None">
                    <CollectionView.EmptyView>
                        <StackLayout Padding="20" VerticalOptions="Center">
                            <Label Text="No rentals found"
                                   HorizontalOptions="Center"
                                   FontSize="18"
                                   TextColor="Gray" />
                        </StackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Rental">
                            <Border Margin="0,5" Padding="10" BackgroundColor="White" Stroke="LightGray" StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>

                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="5">
                                    <!-- Item Title -->
                                    <Label Grid.Row="0"
                                           Text="{Binding Item.Title}"
                                           FontSize="18"
                                           FontAttributes="Bold" />

                                    <!-- Dates -->
                                    <Label Grid.Row="1"
                                           Text="{Binding StartDate, StringFormat='From: {0:dd/MM/yyyy}'}"
                                           FontSize="14"
                                           TextColor="Gray" />

                                    <Label Grid.Row="2"
                                           Text="{Binding EndDate, StringFormat='To: {0:dd/MM/yyyy}'}"
                                           FontSize="14"
                                           TextColor="Gray" />

                                    <!-- Status and Actions -->
                                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,5,0,0">
                                        <Label Grid.Column="0"
                                               Text="{Binding Status}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center" />

                                        <HorizontalStackLayout Grid.Column="1" Spacing="5">
                                            <Button Text="Cancel"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RentalsViewModel}}, Path=CancelRentalCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="Red"
                                                    TextColor="White"
                                                    FontSize="12"
                                                    Padding="10,5"
                                                    IsVisible="{Binding Status, Converter={StaticResource StringEqualityConverter}, ConverterParameter=Pending}" />
                                            <Button Text="Review"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RentalsViewModel}}, Path=LeaveReviewCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="Green"
                                                    TextColor="White"
                                                    FontSize="12"
                                                    Padding="10,5"
                                                    IsVisible="{Binding Status, Converter={StaticResource StringEqualityConverter}, ConverterParameter=Completed}" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

            <!-- My Listings Tab -->
            <RefreshView IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}"
                         IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}">
                <CollectionView ItemsSource="{Binding MyListings}"
                                SelectionMode="None">
                    <CollectionView.EmptyView>
                        <StackLayout Padding="20" VerticalOptions="Center">
                            <Label Text="No rental requests found"
                                   HorizontalOptions="Center"
                                   FontSize="18"
                                   TextColor="Gray" />
                        </StackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Rental">
                            <Border Margin="0,5" Padding="10" BackgroundColor="White" Stroke="LightGray" StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>

                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="5">
                                    <!-- Item Title -->
                                    <Label Grid.Row="0"
                                           Text="{Binding Item.Title}"
                                           FontSize="18"
                                           FontAttributes="Bold" />

                                    <!-- Renter -->
                                    <Label Grid.Row="1"
                                           Text="{Binding Renter.Email, StringFormat='Renter: {0}'}"
                                           FontSize="14"
                                           TextColor="Gray" />

                                    <!-- Dates -->
                                    <Label Grid.Row="2"
                                           Text="{Binding StartDate, StringFormat='From: {0:dd/MM/yyyy}'}"
                                           FontSize="14"
                                           TextColor="Gray" />

                                    <Label Grid.Row="3"
                                           Text="{Binding EndDate, StringFormat='To: {0:dd/MM/yyyy}'}"
                                           FontSize="14"
                                           TextColor="Gray" />

                                    <!-- Status and Actions -->
                                    <Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,5,0,0">
                                        <Label Grid.Column="0"
                                               Text="{Binding Status}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center" />

                                        <HorizontalStackLayout Grid.Column="1" Spacing="5">
                                            <Button Text="Approve"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RentalsViewModel}}, Path=ApproveRentalCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="Green"
                                                    TextColor="White"
                                                    FontSize="12"
                                                    Padding="10,5"
                                                    IsVisible="{Binding Status, Converter={StaticResource StringEqualityConverter}, ConverterParameter=Pending}" />
                                            <Button Text="Complete"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RentalsViewModel}}, Path=CompleteRentalCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="Blue"
                                                    TextColor="White"
                                                    FontSize="12"
                                                    Padding="10,5"
                                                    IsVisible="{Binding Status, Converter={StaticResource StringEqualityConverter}, ConverterParameter=Active}" />
                                            <Button Text="Cancel"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RentalsViewModel}}, Path=CancelRentalCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="Red"
                                                    TextColor="White"
                                                    FontSize="12"
                                                    Padding="10,5" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

            <!-- Loading Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>
